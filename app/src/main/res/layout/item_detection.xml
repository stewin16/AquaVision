<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_detection_card"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical">

    <!-- Color indicator dot -->
    <View
        android:id="@+id/colorIndicator"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_ai_avatar" />

    <!-- Info column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/fishName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            tools:text="Rohu Fish (5)" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/confidenceBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:trackCornerRadius="4dp"
                app:trackThickness="6dp"
                app:indicatorColor="#0891B2"
                app:trackColor="#0D1520"
                android:progress="85" />

            <TextView
                android:id="@+id/confidenceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textSize="12sp"
                android:textColor="#6B7DB3"
                android:fontFamily="sans-serif"
                tools:text="85%" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>